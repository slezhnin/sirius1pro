[credential]
    helper = osxkeychain
[diff]
    tool = vscode
	colorMoved = default
[merge]
    tool = vscode
	conflictstyle = diff3
[difftool "vscode"]
    cmd = code --wait --diff $LOCAL $REMOTE
[mergetool "vscode"]
    cmd = code --wait $MERGED
[user]
    name = Sergey Lezhnin
    email = s.lezhnin@gmail.com
[core]
    editor = nvim \"+norm! a`git branch --show-current`: \" \"+norm! ea\"
	pager = delta
[alias]
    r = !GIT_NO_PAGER=1 git l -30
    l = "!. ~/sirius1pro/.githelpers && pretty_git_log"
[color]
    ui = auto
[color "branch"]
    current = yellow
    local = 241
    remote = green
[color "diff"]
    meta = yellow
    frag = magenta
    old = red
    new = green
[color "status"]
    added = green
    changed = yellow
    untracked = magenta
[includeif "gitdir:~/work/"]
    path = ~/work/.gitconfig
[delta]
	side-by-side = true
	navigate = true
[interactive]
	diffFilter = delta --color-only
